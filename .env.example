# ==============================================================
# The Dispatch — environment variables (EXAMPLE)
# ==============================================================
# Copy this file to .env and fill in your actual keys.
# DO NOT commit .env to git — it's in .gitignore for security.

# RapidAPI key — used for the article summarizer (single-URL tool).
# Get one free at https://rapidapi.com (sign up, subscribe to "Article Extractor and Summarizer")
RAPIDAPI_KEY=your_rapidapi_key_here

# OpenRouter API key — used by the Nepali aggregator to summarize via Llama models.
# Get one free at https://openrouter.ai/settings/keys (no credit card).
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# MyMemory translation email — raises the free quota to 50k chars/day.
# Use any email (can be fake, doesn't need to be verified)
MYMEMORY_EMAIL=your-email@example.com

# Server port (3000 by default)
PORT=3000

# How often the aggregator scrapes Nepali news sites, in minutes (minimum 5)
SCRAPE_INTERVAL_MINUTES=10

# Optional admin token for /api/admin/scrape-now endpoint
# Leave blank for local development; set on production for security
ADMIN_TOKEN=
